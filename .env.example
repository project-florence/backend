GOOGLE_APPLICATION_CREDENTIALS="path/to/your-service-account.json"
COLLECT_API_KEY=your_collect_api_key
POSTGRES_PASSWORD=your_postgres_password
SECRET_KEY=your_jwt_secret_key
FRED_API_KEY="your_fred_api_key"
EVDS_API_KEY="your_evds_api_key"
OPENROUTER_API_KEY="sk-or-v1-your_openrouter_api_key"
CUSTOM_API_KEY="your-custom-api-key"

# Ports
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
REDIS_HOST=localhost
REDIS_PORT=5434
SEARXNG_HOST_PORT=5435
API_HOST_PORT=7055

# Embedding
EMBEDDING_API_KEY=ollama
EMBEDDING_BASE_URL=http://127.0.0.1:11434/v1
EMBEDDING_MODEL=mxbai-embed-large

# LLM
OPENROUTER_URL=https://openrouter.ai/api/v1
CUSTOM_URL=http://localhost:7777/v1
CUSTOM_MODEL=gemma

# News search
NEWS_SEARCH_URL=http://localhost:5435/search
NEWS_SEARCH_USER_AGENT="Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36"
